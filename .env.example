# ==============================================================================
# StayChat Grand Hotel Assistant - Environment Configuration Template
# Duplicate this file as '.env' and populate the actual secrets.
# ==============================================================================

# Primary Gemini API Authentication Key
GEMINI_API_KEY="your-gemini-api-key-here"

# Comma-separated pool of multiple Gemini API keys for active rotator eviction
GEMINI_API_KEYS="key-1,key-2,key-3"

# Application Environment (development, testing, production)
APP_ENV="development"

# Vector Search Thresholds
# Similarity score range 0.0 - 1.0 (cosine similarity). Refuse if below this threshold:
FAISS_SIMILARITY_THRESHOLD=0.65

# RAG Configuration
TOP_K_RESULTS=4
MAX_HISTORY_TURNS=6
